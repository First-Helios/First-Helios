# BLS API v2 — free registration at https://data.bls.gov/registrationEngine/
# Provides 500 requests/day, 50 series per POST, 20-year windows
BLS_API_KEY=your_api_key_here

# Census API — free registration at https://api.census.gov/data/key_signup.html
# Required for Census Bureau Population Estimates, CBP (County Business Patterns)
CBP_API_KEY=your_api_key_here

# Reddit API — OAuth credentials for PRAW (Official Reddit API)
# Optional: if not set, falls back to public JSON API (rate-limited)
# Register at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# USAJobs API — federal job listings
# Register at https://developer.usajobs.gov/APIRequest/Index
USAJOBS_API_KEY=your_api_key_here
USAJOBS_EMAIL=your_email@example.com

# Google Maps / Geocoding — Optional, if using map-based enrichment
# Get key at https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_api_key_here

# Local Flask development
FLASK_ENV=development
FLASK_DEBUG=0

# Database — PostgreSQL (recommended). Leave unset to fall back to SQLite at data/tracker.db.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/helios

# Server config
SERVER_HOST=localhost
SERVER_PORT=8765
