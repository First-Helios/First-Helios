{
  "manifest_version": 3,
  "name": "SpiritPool",
  "version": "0.1.0",
  "description": "Crowdsourced staffing intelligence — contribute job listing observations as you browse.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.indeed.com/*",
    "https://www.linkedin.com/*",
    "https://www.glassdoor.com/*",
    "https://www.google.com/maps/*",
    "https://apply.starbucks.com/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.indeed.com/*"],
      "js": ["compat/browser-polyfill.js", "shared/highlight.js", "shared/scanner.js", "content/indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["compat/browser-polyfill.js", "shared/highlight.js", "shared/scanner.js", "content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.glassdoor.com/*"],
      "js": ["compat/browser-polyfill.js", "shared/highlight.js", "shared/scanner.js", "content/glassdoor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["compat/browser-polyfill.js", "shared/highlight.js", "shared/scanner.js", "content/google-maps.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://apply.starbucks.com/*"],
      "js": ["compat/browser-polyfill.js", "shared/highlight.js", "shared/scanner.js", "content/starbucks-careers.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["shared/selectors.json"],
      "matches": [
        "https://www.indeed.com/*",
        "https://www.linkedin.com/*",
        "https://www.glassdoor.com/*",
        "https://www.google.com/*",
        "https://apply.starbucks.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
