{
  "_version": 1,
  "_updated": "2026-03-16",
  "_note": "Patterns for programmatic DOM scanning. Selectors are tried in order; first match wins. Text patterns use regex. Update this file when sites change layouts — no code changes needed.",

  "linkedin.com": {
    "targetCompanies": ["starbucks", "starbucks coffee"],

    "cardDiscovery": {
      "_doc": "Heuristics to find repeated job card containers in the DOM",
      "selectors": [
        "[data-job-id]",
        "[data-occludable-job-id]",
        ".job-card-container",
        ".jobs-search-results__list-item",
        ".job-card-list",
        "li.ember-view[id^='ember']",
        ".scaffold-layout__list-item",
        ".base-card",
        ".base-search-card"
      ],
      "listContainerSelectors": [
        ".jobs-search-results-list",
        ".scaffold-layout__list",
        ".jobs-search__results-list",
        "[role='list']"
      ],
      "minCardTextLength": 30,
      "maxCardTextLength": 3000
    },

    "fieldExtraction": {
      "jobTitle": {
        "selectors": [
          "a[data-control-name='jobTitle'] strong",
          ".job-card-list__title--link strong",
          ".job-card-list__title",
          "a.job-card-container__link strong",
          ".base-search-card__title",
          "h3 a strong",
          "h3 strong",
          "h3 a",
          "h3"
        ],
        "ariaLabels": ["job title", "title"],
        "headingLevel": [3],
        "textPatterns": []
      },
      "company": {
        "selectors": [
          ".job-card-container__primary-description",
          ".artdeco-entity-lockup__subtitle",
          ".base-search-card__subtitle a",
          "h4.base-search-card__subtitle",
          ".job-card-container__company-name",
          "a[data-tracking-control-name*='company']",
          "h4 a",
          "h4"
        ],
        "ariaLabels": ["company", "company name"],
        "textPatterns": []
      },
      "location": {
        "selectors": [
          ".job-card-container__metadata-item",
          ".artdeco-entity-lockup__caption",
          ".job-search-card__location",
          ".job-card-container__metadata-wrapper .t-14",
          "span.tvm__text"
        ],
        "textPatterns": [
          "\\b[A-Z][a-z]+(?:\\s[A-Z][a-z]+)*,\\s*[A-Z]{2}\\b",
          "\\b[A-Z][a-z]+,\\s*[A-Z][a-z]+,\\s*[A-Z]{2}\\b",
          "Remote",
          "Hybrid",
          "On-site"
        ]
      },
      "salary": {
        "selectors": [
          ".job-card-container__salary-info",
          ".salary-main-rail__min-max",
          "[class*='salary']",
          "[class*='compensation']"
        ],
        "textPatterns": [
          "\\$\\s*[\\d,]+(?:\\.\\d{1,2})?(?:\\s*[-–—to]+\\s*\\$\\s*[\\d,]+(?:\\.\\d{1,2})?)?\\s*(?:/\\s*)?(?:hr|hour|yr|year|mo|month|week)?",
          "\\$\\d[\\d,.]*[kK]?\\s*[-–—]\\s*\\$\\d[\\d,.]*[kK]?"
        ]
      },
      "postingDate": {
        "selectors": [
          "time",
          "time[datetime]",
          ".job-card-container__listed-time",
          ".job-search-card__listdate",
          "[class*='listed']",
          "[class*='posted']"
        ],
        "attributes": ["datetime"],
        "textPatterns": [
          "\\d+\\s*(?:minute|hour|day|week|month)s?\\s+ago",
          "Just\\s+(?:posted|now)",
          "Reposted",
          "Today"
        ]
      },
      "applicantCount": {
        "selectors": [
          ".job-card-container__applicant-count",
          "[class*='applicant']"
        ],
        "textPatterns": [
          "(\\d[\\d,]*)\\+?\\s*applicants?",
          "Be (?:among )?(?:the )?first\\s+(\\d+)\\s*applicants?",
          "Over\\s+(\\d[\\d,]*)\\s*applicants?"
        ]
      },
      "badges": {
        "selectors": [
          ".job-card-container__footer-item",
          "[class*='insight']",
          "[class*='badge']",
          ".job-card-container__apply-method"
        ],
        "textMarkers": [
          "Easy Apply",
          "Reposted",
          "Promoted",
          "Actively recruiting",
          "Early applicant",
          "Be an early applicant",
          "Viewed"
        ]
      }
    },

    "detailPanel": {
      "_doc": "The right-side job detail panel or full-page job view",
      "containerSelectors": [
        ".jobs-search__job-details",
        ".job-view-layout",
        ".jobs-details",
        ".jobs-unified-top-card",
        ".job-details-jobs-unified-top-card"
      ],
      "titleSelectors": [
        "h1.t-24",
        "h1",
        "h2.t-24",
        ".jobs-unified-top-card__job-title",
        ".job-details-jobs-unified-top-card__job-title"
      ],
      "companySelectors": [
        ".jobs-unified-top-card__company-name a",
        ".job-details-jobs-unified-top-card__company-name a",
        "a[data-tracking-control-name*='company']",
        ".jobs-unified-top-card__company-name"
      ],
      "locationSelectors": [
        ".jobs-unified-top-card__bullet",
        ".job-details-jobs-unified-top-card__bullet",
        ".jobs-unified-top-card__workplace-type"
      ],
      "applicantSelectors": [
        ".jobs-unified-top-card__applicant-count",
        ".job-details-jobs-unified-top-card__applicant-count",
        "[class*='applicant-count']"
      ]
    },

    "exclusions": {
      "_doc": "Elements to skip during scanning (nav, footer, ads)",
      "containerSelectors": [
        "nav",
        "header",
        "footer",
        ".global-nav",
        ".scaffold-layout__sidebar",
        ".msg-overlay-list-bubble",
        "#msg-overlay",
        ".share-box",
        "[role='banner']",
        "[role='navigation']",
        "[role='contentinfo']"
      ],
      "classSubstrings": [
        "nav", "footer", "header", "msg-", "share-box",
        "ad-banner", "premium-upsell", "notification"
      ]
    }
  },

  "indeed.com": {
    "targetCompanies": ["starbucks", "starbucks coffee company"],

    "cardDiscovery": {
      "selectors": [
        ".job_seen_beacon",
        ".resultContent",
        ".tapItem",
        "[data-jk]",
        ".slider_item",
        "[data-testid='slider_item']",
        ".jobsearch-ResultsList .result"
      ]
    },

    "fieldExtraction": {
      "jobTitle": {
        "selectors": [
          "h2.jobTitle a span",
          "h2.jobTitle span",
          "[data-testid='jobTitle']",
          ".jobTitle a",
          ".jobTitle"
        ]
      },
      "company": {
        "selectors": [
          "[data-testid='company-name']",
          ".companyName",
          ".company"
        ]
      },
      "location": {
        "selectors": [
          "[data-testid='text-location']",
          ".companyLocation",
          ".location"
        ]
      },
      "salary": {
        "selectors": [
          ".salary-snippet-container",
          "[data-testid='attribute_snippet_testid']",
          ".salaryText",
          "[class*='salary']"
        ],
        "textPatterns": [
          "\\$[\\d,]+(?:\\.\\d{2})?(?:\\s*[-–]\\s*\\$[\\d,]+(?:\\.\\d{2})?)?(?:\\s*(?:an? )?(?:hour|year|month|week))?",
          "From \\$[\\d,]+(?:\\.\\d{2})?"
        ]
      },
      "postingDate": {
        "selectors": [
          ".date",
          "[data-testid='myJobsStateDate']",
          "span.css-qvloho",
          ".new"
        ],
        "textPatterns": [
          "\\d+\\s*days?\\s+ago",
          "Just\\s+posted",
          "Today",
          "PostedPosted\\s+\\d+\\s*days?\\s*ago"
        ]
      },
      "applicantCount": {
        "textPatterns": ["(\\d+)\\+?\\s*applicants?"]
      },
      "badges": {
        "selectors": [
          ".urgentlyHiring",
          "[data-testid='urgentlyHiring']",
          ".tapItem .badge"
        ],
        "textMarkers": ["Urgently hiring", "Hiring multiple candidates", "Responded to 75%+ of applications"]
      }
    }
  },

  "glassdoor.com": {
    "targetCompanies": ["starbucks"],

    "cardDiscovery": {
      "selectors": [
        ".react-job-listing",
        "[data-test='jobListing']",
        ".job-listing",
        "li.jl"
      ]
    },

    "fieldExtraction": {
      "jobTitle": {
        "selectors": [
          ".job-title",
          "a[data-test='job-link']",
          "h2 a",
          ".jobTitle"
        ]
      },
      "company": {
        "selectors": [
          "[data-test='emp-name']",
          ".employer-name",
          ".job-search-key-l2wjgv"
        ]
      },
      "location": {
        "selectors": [
          "[data-test='emp-location']",
          ".location",
          ".job-search-key-iii2h0"
        ]
      },
      "salary": {
        "selectors": [
          "[data-test='detailSalary']",
          ".salary-estimate",
          "[class*='salary']"
        ]
      },
      "postingDate": {
        "selectors": [
          ".listing-age",
          "[data-test='job-age']"
        ],
        "textPatterns": ["(\\d+)d", "(\\d+)h", "(\\d+)w"]
      }
    }
  },

  "google.com/maps": {
    "targetCompanies": ["starbucks"],

    "fieldExtraction": {
      "storeName": {
        "selectors": ["h1.DUwDvf", "h1.fontHeadlineLarge", "div.tAiQdd h1", "h1"]
      },
      "address": {
        "selectors": [
          "[data-item-id='address'] .fontBodyMedium",
          "button[data-item-id='address']",
          "[aria-label*='Address']"
        ]
      },
      "rating": {
        "selectors": [
          "div.F7nice span[aria-hidden='true']",
          "span.ceNzKf",
          ".fontDisplayLarge"
        ]
      },
      "reviewCount": {
        "selectors": ["div.F7nice span:last-child", "button[jsaction*='review'] span"]
      }
    },

    "reviewKeywords": [
      "understaffed", "short-staffed", "short staffed", "slow service",
      "long wait", "waiting forever", "no staff", "only one person",
      "closed early", "nobody working", "skeleton crew", "overwhelmed",
      "drive thru line", "drive through line", "took forever",
      "barely any employees", "one barista", "understaffing"
    ]
  },

  "apply.starbucks.com": {
    "cardDiscovery": {
      "selectors": [
        ".job-card",
        ".job-list-item",
        ".search-result-item",
        "[data-automation='jobListing']",
        "tr.job-row"
      ]
    },

    "fieldExtraction": {
      "jobTitle": {
        "selectors": [".job-title", "h3", "h2", "a[href*='/job/']"]
      },
      "location": {
        "selectors": [".job-location", ".location", "span.city"]
      },
      "postingDate": {
        "selectors": [".job-date", ".posted-date", "time"]
      },
      "category": {
        "selectors": [".job-category", ".category"]
      }
    }
  }
}
